{
  "appId": "com.dailyorganizer.desktopapp",
  "productName": "Daily Life Organizer",
  "directories": {
    "output": "dist"
  },
  "files": [
    "**/*",
    "!**/node_modules/**/*",
    "node_modules/electron/**/*"
  ],
  "win": {
    "target": "nsis",
    "artifactName": "${productName}_Setup_${version}.${ext}"
  },
  "mac": {
    "target": "dmg",
    "artifactName": "${productName}_${version}.${ext}"
  },
  "linux": {
    "target": "AppImage",
    "artifactName": "${productName}_${version}.${ext}"
  }
}